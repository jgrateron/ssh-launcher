# SSH Launcher - Sample Config for Testing
# Copy to ~/.ssh/config before running the app

Host prod-web-01
    HostName 192.168.1.10
    User admin
    Port 22

Host staging-db
    HostName 10.0.0.5
    User deploy
    Port 2222

Host backup-srv
    HostName backup.example.com
    User root

Host monitoring
    HostName monitor.internal
    User nagios

Host legacy-app
    HostName 172.16.0.50
    User maintenance

Host alpha-dev
    HostName dev1.example.com
    IdentityFile ~/.ssh/dev_key

Host beta-api
    HostName api-beta.example.com
    Port 2222

Host production-db
    HostName db.prod.example.com
    User dba
    StrictHostKeyChecking yes

Host *github*
    IdentityFile ~/.ssh/github_rsa

Host *.example.com
    User default-user
    ForwardAgent yes
